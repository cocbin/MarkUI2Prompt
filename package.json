{
  "name": "ui2prompt",
  "version": "1.0.0",
  "private": true,
  "description": "Chrome extension for UI annotation, fix verification, and structured agent prompt export.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "icons": "node scripts/gen-icons.mjs",
    "build": "node scripts/gen-icons.mjs && node build.mjs",
    "watch": "node build.mjs --watch",
    "harness": "npm run build && node scripts/build-harness.mjs",
    "serve": "node scripts/dev-server.mjs dist 5180",
    "broker": "node server/broker.mjs",
    "mcp": "node server/mcp.mjs",
    "skill": "node scripts/build-skill.mjs",
    "install-skill": "node scripts/build-skill.mjs && bash scripts/install-skill.sh",
    "demo": "node scripts/dev-server.mjs demo 5179",
    "package": "npm run build && cd dist && zip -r ../ui2prompt-dist.zip . && cd ..",
    "clean": "rm -rf dist ui2prompt-dist.zip"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
